# ─── QA Intelligence System — Variables de entorno ───────────────────────────
# Copia este archivo como .env y completa tus valores reales
# Nunca subas .env a tu repositorio (agrégalo a .gitignore)

# Claude API (obtén tu key en https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Jira (token en https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_BASE_URL=https://tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_TOKEN=tu_jira_api_token
JIRA_PROJECT=QA
